# Public site URL (production: https://hylith.com — used for canonical URLs & OG)
# NEXT_PUBLIC_SITE_URL=https://hylith.com

# Google Search Console HTML tag verification (optional)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Auth (NextAuth)
AUTH_SECRET=
AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase API (required for the app)
NEXT_PUBLIC_SUPABASE_URL=https://kfqtfbvatlqspmvugpwm.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# Database migrations (npm run db:migrate) — pick ONE approach
# ---------------------------------------------------------------------------

# A) Session pooler (recommended on Windows / IPv4)
# Dashboard → Connect → Session pooler → copy URI
# User must be postgres.[project-ref], host like aws-1-ap-northeast-2.pooler.supabase.com
# SUPABASE_DB_URL=postgresql://postgres.kfqtfbvatlqspmvugpwm:[PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres

# B) Direct connection (IPv6 only — Dashboard → Connection string)
# User is postgres (no project suffix), host db.[project-ref].supabase.co
# SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.kfqtfbvatlqspmvugpwm.supabase.co:5432/postgres

# C) Auto-try pooler + direct (password + region from pooler tab)
SUPABASE_DB_PASSWORD=
SUPABASE_DB_REGION=ap-northeast-2
# SUPABASE_DB_HOST=aws-1-ap-northeast-2.pooler.supabase.com

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

AGENCY_NOTIFICATION_EMAIL=
AGENCY_TIMEZONE=Asia/Dhaka
